{
  "name": "project-prompt-library",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Proof-first ChatGPT Apps / MCP connector for invoking exact prompt-library commands.",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "tsx src/mcp/server.ts",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run test/unit",
    "test:contract": "vitest run test/contract",
    "test:golden": "vitest run test/golden",
    "validate-prompts": "tsx scripts/validate-prompts.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.13.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  }
}
